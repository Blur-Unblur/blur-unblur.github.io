---
interface Props {
  icon: string;
  title: string;
  body: string;
}

const { icon, title, body } = Astro.props;
---

<article class="rounded-2xl border border-outline-variant bg-white p-8 shadow-sm transition-transform duration-300 hover:-translate-y-2">
  <div class="mb-6 grid size-12 place-items-center rounded-xl bg-primary/10 text-primary">
    <span class="material-symbols-outlined" aria-hidden="true">{icon}</span>
  </div>
  <h3 class="text-2xl font-semibold text-on-surface">{title}</h3>
  <p class="mt-3 text-base leading-6 text-on-surface-variant">{body}</p>
</article>
