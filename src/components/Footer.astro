---
import LogoMarquee from "./LogoMarquee.astro";
---

<LogoMarquee />

<footer class="border-t border-outline-variant bg-white">
  <div class="section-shell flex flex-col items-center justify-between gap-8 py-8 text-sm text-on-surface-variant md:flex-row">
    <div class="flex items-center gap-2">
      <img class="size-8 rounded-md object-cover" src="/icon-192.png" alt="Blur and Unblur AI logo" width="32" height="32" loading="lazy" />
      <span class="text-lg font-bold text-on-surface">Blur &amp; Unblur AI</span>
    </div>
    <div class="flex flex-wrap justify-center gap-5 md:gap-8">
      <a class="focus-ring rounded-md transition hover:text-primary" href="/#features">Key features</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/#tool">Blur faces</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/#use-cases">Use cases</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/#faq">Questions</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/privacy/">Privacy notice</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/terms/">Terms of use</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/cookies/">Cookie policy</a>
      <a class="focus-ring rounded-md transition hover:text-primary" href="/contact/">GitHub contact</a>
    </div>
    <p class="text-xs opacity-80">© 2026 Blur &amp; Unblur AI</p>
  </div>
</footer>
