---
const navItems = [
  { href: "#features", label: "Features" },
  { href: "#tech", label: "Tech" },
  { href: "#faq", label: "FAQ" },
];
---

<header class="sticky top-0 z-50 border-b border-outline-variant bg-white/80 backdrop-blur-lg">
  <nav class="section-shell flex items-center justify-between gap-4 py-4">
    <a href="/" class="focus-ring flex items-center gap-2 rounded-lg text-on-surface">
      <img class="size-10 rounded-lg object-cover" src="/icon-192.png" alt="" width="40" height="40" />
      <span class="text-xl font-bold tracking-normal">Blur &amp; Unblur AI</span>
    </a>
    <div class="hidden items-center gap-8 md:flex">
      {navItems.map((item, index) => (
        <a class:list={["focus-ring rounded-md pb-1 text-base transition-colors", index === 0 ? "border-b-2 border-primary font-semibold text-primary" : "text-on-surface-variant hover:text-primary"]} href={item.href}>
          {item.label}
        </a>
      ))}
    </div>
    <a
      href="#tool"
      class="focus-ring inline-flex items-center rounded-xl bg-primary px-6 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-primary-container"
    >
      Get Started Free
    </a>
  </nav>
</header>
