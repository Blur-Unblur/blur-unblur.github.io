---
interface Props {
	eyebrow?: string;
}

const { eyebrow = 'Trusted by builders who care about face privacy' } = Astro.props;
---

<section
	class='border-t border-outline-variant bg-surface-container-low py-8'
	aria-label='Partner logos'>
	<div class='section-shell'>
		<p class='mb-5 text-center text-xs font-bold uppercase tracking-widest text-on-surface-variant'>
			{eyebrow}
		</p>
		<div
			class='logo-marquee'
			data-logo-marquee>
			<div
				class='logo-marquee__track'
				data-logo-marquee-track>
				<a
					href='https://openhunts.com'
					target='_blank'
					title='OpenHunts Club'>
					<img
						alt='OpenHunts Club Member'
						height='105'
						src='https://cdn.openhunts.com/badges/club.webp'
						style='width: 195px; height: auto;'
						width='486'
					/>
				</a>
				<a
					href='https://kittylaunch.com/p/blur-unblur-ai'
					target='_blank'
					rel='noopener'>
					<img
						src='https://kittylaunch.com/api/public/badges/launch_badge.svg?theme=light&name=Blur%20%26%20Unblur%20AI'
						width='280'
						alt='Blur & Unblur AI on KittyLaunch'
						data-kittylaunch-badge='1'
					/>
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	const setupLogoMarquee = () => {
		document.querySelectorAll('[data-logo-marquee]').forEach((marquee) => {
			const track = marquee.querySelector('[data-logo-marquee-track]');
			if (!track || track.dataset.marqueeReady === 'true') return;

			track.querySelectorAll('[data-marquee-clone]').forEach((clone) => clone.remove());

			const originalItems = [...track.children];
			if (originalItems.length === 0) return;

			const firstItem = originalItems[0];
			const lastItem = originalItems[originalItems.length - 1];
			const start = firstItem.getBoundingClientRect().left;
			const end = lastItem.getBoundingClientRect().right;
			const setWidth = Math.max(1, end - start);

			track.style.setProperty('--logo-marquee-distance', `${setWidth}px`);

			const requiredWidth = marquee.getBoundingClientRect().width * 2 + setWidth;
			while (track.scrollWidth < requiredWidth) {
				originalItems.forEach((item) => {
					const clone = item.cloneNode(true);
					clone.dataset.marqueeClone = 'true';
					clone.setAttribute('aria-hidden', 'true');
					clone.setAttribute('tabindex', '-1');
					track.append(clone);
				});
			}

			track.dataset.marqueeReady = 'true';
		});
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupLogoMarquee, { once: true });
	} else {
		setupLogoMarquee();
	}

	window.addEventListener('resize', () => {
		document.querySelectorAll('[data-logo-marquee-track]').forEach((track) => {
			track.dataset.marqueeReady = 'false';
			track.querySelectorAll('[data-marquee-clone]').forEach((clone) => clone.remove());
		});
		setupLogoMarquee();
	});
</script>

<style>
	.logo-marquee {
		position: relative;
		overflow: hidden;
		mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent);
	}

	.logo-marquee__track {
		display: flex;
		width: max-content;
		gap: 1rem;
		padding-block: 0.25rem;
		animation: logo-marquee-scroll-left 24s linear infinite;
		will-change: transform;
	}

	.logo-marquee:hover .logo-marquee__track {
		animation-play-state: paused;
	}

	.logo-marquee__track > * {
		display: grid;
		min-width: 11rem;
		height: 4.5rem;
		flex: 0 0 auto;
		place-items: center;
		border: 1px solid var(--color-outline-variant);
		border-radius: 1rem;
		background: rgb(255 255 255 / 0.82);
		padding: 1rem 1.25rem;
		transition:
			border-color 180ms ease,
			transform 180ms ease,
			background-color 180ms ease;
	}

	.logo-marquee__track > *:hover {
		border-color: var(--color-primary);
		background: #fff;
		transform: translateY(-2px);
	}

	.logo-marquee__track img {
		display: block;
		max-height: 2.7rem;
		max-width: 9.5rem;
		object-fit: contain;
	}

	@keyframes logo-marquee-scroll-left {
		from {
			transform: translate3d(0, 0, 0);
		}

		to {
			transform: translate3d(calc(-1 * var(--logo-marquee-distance, 22rem)), 0, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.logo-marquee__track {
			animation: none;
			flex-wrap: wrap;
			justify-content: center;
			width: 100%;
		}
	}

	@media (max-width: 640px) {
		.logo-marquee__track > * {
			min-width: 9rem;
			height: 4rem;
		}
	}
</style>
