<script>
	const setupLogoMarquee = () => {
		document.querySelectorAll('[data-logo-marquee]').forEach((marquee) => {
			const track = marquee.querySelector('[data-logo-marquee-track]');
			if (!track || track.dataset.marqueeReady === 'true') return;

			track.querySelectorAll('[data-marquee-clone]').forEach((clone) => clone.remove());

			const originalItems = [...track.children];
			if (originalItems.length === 0) return;

			const firstItem = originalItems[0];
			const lastItem = originalItems[originalItems.length - 1];
			const start = firstItem.getBoundingClientRect().left;
			const end = lastItem.getBoundingClientRect().right;
			const setWidth = Math.max(1, end - start);

			track.style.setProperty('--logo-marquee-distance', `${setWidth}px`);

			const requiredWidth = marquee.getBoundingClientRect().width * 2 + setWidth;
			while (track.scrollWidth < requiredWidth) {
				originalItems.forEach((item) => {
					const clone = item.cloneNode(true);
					clone.dataset.marqueeClone = 'true';
					clone.setAttribute('aria-hidden', 'true');
					clone.setAttribute('tabindex', '-1');
					track.append(clone);
				});
			}

			track.dataset.marqueeReady = 'true';
		});
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupLogoMarquee, { once: true });
	} else {
		setupLogoMarquee();
	}

	window.addEventListener('resize', () => {
		document.querySelectorAll('[data-logo-marquee-track]').forEach((track) => {
			track.dataset.marqueeReady = 'false';
			track.querySelectorAll('[data-marquee-clone]').forEach((clone) => clone.remove());
		});
		setupLogoMarquee();
	});
</script>

