---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: "Terms of Use",
  description: "Terms for using Blur & Unblur AI as a browser-based face blur and face mask editor.",
};
---

<Layout
  title="Terms of Use | Blur & Unblur AI"
  description="Read the terms for using Blur & Unblur AI to blur faces online with local editing, face masks, downloads, and limitations."
  structuredData={structuredData}
>
  <Header />
  <main class="bg-background py-20">
    <article class="section-shell max-w-4xl rounded-3xl border border-outline-variant bg-white p-8 shadow-sm md:p-12">
      <p class="mb-3 text-sm font-bold uppercase tracking-widest text-primary">Terms</p>
      <h1 class="mb-6 text-4xl font-bold text-on-surface">Terms of Use</h1>
      <div class="space-y-6 text-base leading-7 text-on-surface-variant">
        <p>
          These terms describe use of Blur &amp; Unblur AI, a free browser-based tool for blurring faces in photos, drawing manual lasso face masks, removing false detections, adjusting blur strength, and downloading edited PNG files.
        </p>
        <p>
          You are responsible for the face photos and images you open, edit, download, and share. Use the face blur editor only with images that you own, have permission to process, or are otherwise allowed to edit under applicable law and platform rules.
        </p>
        <p>
          The service is provided as-is. Face detection, face blur strength, lasso masks, and canvas export can vary by browser, device performance, image quality, lighting, angle, and file size. Always inspect the final blurred image before publishing it or relying on it for privacy protection.
        </p>
        <p>
          Do not use the service for harassment, impersonation, unlawful surveillance, non-consensual publication, or any activity that violates another person's rights. If a platform or jurisdiction requires stronger redaction than visual blur, use a professional redaction workflow.
        </p>
        <p>
          Blur &amp; Unblur AI may change, improve, or remove features without notice. Continued use of the site means you accept the current version of these terms.
        </p>
        <p>
          Review the <a class="font-semibold text-primary underline" href="/privacy/">Privacy Policy</a>, <a class="font-semibold text-primary underline" href="/cookies/">Cookie Policy</a>, or <a class="font-semibold text-primary underline" href="/contact/">Contact page</a> for related information.
        </p>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
