---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "Blur Unblur | Private Face Blur Studio",
  description = "Blur photos or selected faces directly in your browser. Automatic face detection, manual lasso, adjustable strength, and private local processing.",
  structuredData,
} = Astro.props;

const configuredSiteUrl = Astro.site?.toString().replace(/\/$/, "");
const siteUrl = import.meta.env.PUBLIC_SITE_URL?.replace(/\/$/, "") || configuredSiteUrl;
const canonicalUrl = siteUrl ? new URL(Astro.url.pathname, siteUrl).toString() : undefined;
const socialImageUrl = siteUrl ? new URL("/og-image.png", siteUrl).toString() : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="theme-color" content="#0058be" />
    <title>{title}</title>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="icon" type="image/png" sizes="16x16" href="/icon-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Blur & Unblur AI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    {socialImageUrl && <meta property="og:image:width" content="1200" />}
    {socialImageUrl && <meta property="og:image:height" content="630" />}
    {socialImageUrl && <meta property="og:image:alt" content="Blur & Unblur AI face privacy editor" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,400,0,0"
    />
    {structuredData && <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />}
  </head>
  <body>
    <slot />
  </body>
</html>
